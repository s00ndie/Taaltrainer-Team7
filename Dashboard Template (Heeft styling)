<!DOCTYPE html>
<html lang="nl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Taal Leren Dashboard</title>
<body>
    <style>
        :root {
            --bg-1: #e9fbff;
            --bg-2: #f8feff;
            --card: #ffffff;
            --text: #114154;
            --muted: #4d7c8c;
            --green: #58cc02;
            --green-dark: #45a500;
            --blue-soft: #dff7ff;
            --border: #c9edf7;
            --shadow: 0 12px 30px rgba(20, 110, 130, 0.12);
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            font-family: "Nunito", sans-serif;
            background:
                radial-gradient(circle at 15% 0%, #d5f7ff 0%, transparent 35%),
                radial-gradient(circle at 100% 100%, #c7f2ff 0%, transparent 36%),
                linear-gradient(160deg, var(--bg-1) 0%, var(--bg-2) 100%);
            color: var(--text);
            padding: 24px;
            min-height: 100vh;
        }

        .container {
            width: min(980px, 100%);
            margin: 0 auto;
            display: grid;
            gap: 16px;
            grid-template-columns: 1.5fr 1fr;
        }

        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 14px;
        }

        .brand {
            display: flex;
            align-items: center;
            gap: 10px;
            font-family: "Baloo 2", cursive;
            font-weight: 800;
            font-size: 1.55rem;
            color: var(--green-dark);
        }

        .logo {
            width: 40px;
            height: 40px;
            border-radius: 12px;
            display: grid;
            place-items: center;
            background: linear-gradient(160deg, #95e64a, var(--green));
            color: #fff;
            font-weight: 800;
        }

        h1 {
            margin: 0;
            font-family: "Baloo 2", cursive;
            font-size: 1.9rem;
            line-height: 1.1;
        }

        .streak {
            background: #fff4cf;
            color: #8a6200;
            padding: 8px 12px;
            border-radius: 999px;
            font-weight: 800;
            font-size: 0.9rem;
        }

        .subtitle {
            margin: 8px 0 16px;
            color: var(--muted);
        }

        .main-card,
        .side-card {
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: 18px;
            box-shadow: var(--shadow);
            padding: 18px;
        }

        .main-card {
            grid-row: span 2;
        }

        .stats {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 10px;
            margin-bottom: 16px;
        }

        .stat {
            background: #f4fdff;
            border: 1px solid #d8f3fa;
            border-radius: 12px;
            padding: 10px;
        }

        .stat-title {
            margin: 0 0 4px;
            color: var(--muted);
            font-size: 0.9rem;
        }

        .stat-value {
            margin: 0;
            font-weight: 800;
            font-size: 1.2rem;
            font-family: "Baloo 2", cursive;
        }

        .progress-label {
            display: flex;
            justify-content: space-between;
            margin-bottom: 8px;
            font-weight: 700;
            color: var(--muted);
        }

        .progress-track {
            background: #dff4fa;
            border-radius: 999px;
            height: 12px;
            overflow: hidden;
            margin-bottom: 18px;
        }

        .progress-fill {
            width: 0%;
            height: 100%;
            border-radius: inherit;
            background: linear-gradient(90deg, #70d629, var(--green));
        }

        .lesson-list {
            display: grid;
            gap: 10px;
        }

        .lesson {
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: var(--blue-soft);
            border: 1px solid #cdeff9;
            border-radius: 12px;
            padding: 10px 12px;
        }

        .lesson-title {
            margin: 0;
            font-weight: 800;
        }

        .lesson-sub {
            margin: 0;
            color: var(--muted);
            font-size: 0.9rem;
        }

        .btn {
            border: 0;
            background: var(--green);
            color: #fff;
            border-radius: 8px;
            padding: 8px 12px;
            font-weight: 800;
            cursor: pointer;
            font-family: "Nunito", sans-serif;
            box-shadow: 0 4px 0 var(--green-dark);
        }

        .side-card h2 {
            margin: 0 0 10px;
            font-family: "Baloo 2", cursive;
            font-size: 1.3rem;
        }

        .goal {
            margin: 0;
            color: var(--muted);
        }

        .goal-strong {
            margin: 8px 0 14px;
            font-weight: 800;
            font-size: 1.15rem;
        }

        .small-list {
            margin: 0;
            padding-left: 20px;
            color: var(--muted);
        }

        @media (max-width: 760px) {
            .container {
                grid-template-columns: 1fr;
            }

            .header {
                flex-direction: column;
                align-items: flex-start;
                gap: 4px;
            }

            .stats {
                grid-template-columns: 1fr;
            }

            .main-card {
                grid-row: auto;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <section class="main-card">
            <header class="header">
                <div class="brand">
                    <div class="logo">T</div>
                    TaalTrainer
                </div>
                <span class="streak">0 dagen streak</span>
            </header>

            <h1>Welkom terug</h1>
            <p class="subtitle">Blijf oefenen en groei elke dag in woordenschat en uitspraak.</p>

            <section class="stats">
                <article class="stat">
                    <p class="stat-title">XP vandaag</p>
                    <p class="stat-value">0 XP</p>
                </article>
                <article class="stat">
                    <p class="stat-title">Doel</p>
                    <p class="stat-value">0 XP</p>
                </article>
                <article class="stat">
                    <p class="stat-title">Niveau</p>
                    <p class="stat-value">A2</p>
                </article>
            </section>

            <div class="progress-label">
                <span>Voortgang Unit 4</span>
                <span>0%</span>
            </div>
            <div class="progress-track">
                <div class="progress-fill"></div>
            </div>

            <section class="lesson-list">
                <article class="lesson">
                    <div>
                        <p class="lesson-title">Restaurant</p>
                        <p class="lesson-sub">5 minuten</p>
                    </div>
                    <button class="btn">Start</button>
                </article>
                <article class="lesson">
                    <div>
                        <p class="lesson-title">Begroetingen</p>
                        <p class="lesson-sub">8 minuten</p>
                    </div>
                    <button class="btn">Start</button>
                </article>
                <article class="lesson">
                    <div>
                        <p class="lesson-title">Reizen</p>
                        <p class="lesson-sub">6 minuten</p>
                    </div>
                    <button class="btn">Start</button>
                </article>
            </section>
        </section>
</body>
</html>
